{
  "name": "njau-libyy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:web && npm run build:server && node dist/server/node/server.js",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "build:server": "esbuild src/node/server.ts --bundle --minify --platform=node --format=esm --target=node22 --outfile=dist/server/node/server.js --external:better-sqlite3 --external:dotenv --external:playwright --external:playwright-core",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/server/node/server.js",
    "admin:promote": "node scripts/promote-admin.mjs",
    "typecheck": "tsc --noEmit && tsc -p apps/web/tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.17.0",
    "playwright": "1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
